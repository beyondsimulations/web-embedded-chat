# ── AI API ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=https://example.com,https://app.example.com

# ── Database ──────────────────────────────────────────────────────────────────
# Only needed in .env — docker-compose.yml builds DATABASE_URL automatically
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── Dashboard Auth ────────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password
# Optional pre-computed Argon2 hash; set this instead of DASHBOARD_PASSWORD to
# skip runtime hashing at startup. Generate with `cargo run --bin hash_password`.
# DASHBOARD_PASSWORD_HASH=

# ── Pseudonymous ID rotation ──────────────────────────────────────────────────
# Salt mixed into the SHA-256 user ID hash. Change between teaching semesters
# (e.g. WS2025-26, SS2026) so prior cohorts cannot be joined to the current one.
# If unset, the salt is empty and IDs do not rotate across deployments.
SEMESTER=WS2025-26

# ── Upstream tuning ───────────────────────────────────────────────────────────
# Cap on max_tokens forwarded to the upstream chat completions endpoint.
# MAX_TOKENS=10000
# HTTP client timeout (seconds) for upstream calls.
# REQUEST_TIMEOUT_SECS=240

# Set to "false" for local development over HTTP (default: true, requires HTTPS)
# SECURE_COOKIES=false
